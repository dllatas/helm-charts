{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["serviceAccounts"],
  "properties": {
    "global": {"type": "object", "additionalProperties": true},
    "serviceAccounts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "namespace"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 63,
            "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
          },
          "namespace": {
            "type": "string",
            "minLength": 1,
            "maxLength": 63,
            "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
          },
          "labels": {
            "type": "object",
            "additionalProperties": {"type": "string"}
          },
          "annotations": {
            "type": "object",
            "additionalProperties": {"type": "string"}
          },
          "automountServiceAccountToken": {"type": "boolean"},
          "imagePullSecrets": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name"],
              "properties": {
                "name": {"type": "string", "minLength": 1}
              }
            }
          },
          "secrets": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name"],
              "properties": {
                "name": {"type": "string", "minLength": 1}
              }
            }
          }
        }
      }
    }
  }
}
