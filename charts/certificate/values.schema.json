{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "certificates"],
  "properties": {
    "global": {"type": "object", "additionalProperties": true},
    "apiVersion": {"type": "string", "enum": ["cert-manager.io/v1"]},
    "certificates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "namespace", "spec"],
        "properties": {
          "name": {"type": "string", "minLength": 1, "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"},
          "namespace": {"type": "string", "minLength": 1, "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"},
          "labels": {"type": "object", "additionalProperties": {"type": "string"}},
          "annotations": {"type": "object", "additionalProperties": {"type": "string"}},
          "spec": {"type": "object", "additionalProperties": true}
        }
      }
    }
  }
}
