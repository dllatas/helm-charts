{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apiVersions",
    "pipeline",
    "publish",
    "run",
    "triggerBinding",
    "triggerTemplate",
    "eventListener",
    "github",
    "httpRoute"
  ],
  "properties": {
    "nameOverride": {"type": "string", "maxLength": 63},
    "fullnameOverride": {"type": "string", "maxLength": 63},
    "apiVersions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tekton", "triggers", "gateway"],
      "properties": {
        "tekton": {"type": "string", "enum": ["tekton.dev/v1beta1", "tekton.dev/v1"]},
        "triggers": {"type": "string", "enum": ["triggers.tekton.dev/v1beta1", "triggers.tekton.dev/v1"]},
        "gateway": {"type": "string", "enum": ["gateway.networking.k8s.io/v1", "gateway.networking.k8s.io/v1beta1"]}
      }
    },
    "pipeline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "serviceAccountName", "toolsImage", "cloneTaskRef"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "serviceAccountName": {"type": "string", "minLength": 1},
        "toolsImage": {"type": "string", "minLength": 1},
        "cloneTaskRef": {"type": "string", "minLength": 1}
      }
    },
    "publish": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "targetBranch", "secretName", "secretKeys"],
      "properties": {
        "enabled": {"type": "boolean"},
        "targetBranch": {"type": "string", "minLength": 1},
        "secretName": {"type": "string", "minLength": 1},
        "secretKeys": {
          "type": "object",
          "additionalProperties": false,
          "required": ["harborRepo", "harborUsername", "harborPassword"],
          "properties": {
            "harborRepo": {"type": "string", "minLength": 1},
            "harborUsername": {"type": "string", "minLength": 1},
            "harborPassword": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workspaceType", "fsGroup", "skipE2E", "sshSecretName", "dockerSecretName"],
      "properties": {
        "workspaceType": {"type": "string", "enum": ["volumeClaimTemplate"]},
        "pvcSize": {"type": "string", "minLength": 1},
        "storageClassName": {"type": "string"},
        "pvcAccessModes": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "fsGroup": {"type": "integer", "minimum": 1},
        "nodeSelector": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "affinity": {
          "type": "object",
          "additionalProperties": true
        },
        "skipE2E": {"type": "boolean"},
        "sshSecretName": {"type": "string", "minLength": 1},
        "dockerSecretName": {"type": "string", "minLength": 1}
      }
    },
    "triggerBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {"type": "string", "minLength": 1}
      }
    },
    "triggerTemplate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {"type": "string", "minLength": 1}
      }
    },
    "eventListener": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "serviceAccountName"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "serviceAccountName": {"type": "string", "minLength": 1},
        "nodeSelector": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "affinity": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "github": {
      "type": "object",
      "additionalProperties": false,
      "required": ["secretName", "secretKey", "eventTypes", "repositoryFullName", "extraFilter"],
      "properties": {
        "secretName": {"type": "string", "minLength": 1},
        "secretKey": {"type": "string", "minLength": 1},
        "eventTypes": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "repositoryFullName": {"type": "string", "minLength": 1},
        "extraFilter": {"type": "string"}
      }
    },
    "httpRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "name", "parentRefs", "hostnames", "pathPrefix"],
      "properties": {
        "enabled": {"type": "boolean"},
        "name": {"type": "string", "minLength": 1},
        "parentRefs": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
        "hostnames": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "pathPrefix": {"type": "string", "minLength": 1}
      }
    }
  }
}
