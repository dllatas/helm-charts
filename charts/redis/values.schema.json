{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "global": {
      "type": "object",
      "additionalProperties": true
    },
    "nameOverride": {
      "type": "string"
    },
    "fullnameOverride": {
      "type": "string"
    },
    "commonLabels": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "tag",
        "pullPolicy"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string",
          "minLength": 1
        },
        "pullPolicy": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "create",
        "annotations",
        "name"
      ],
      "properties": {
        "create": {
          "type": "boolean"
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "name": {
          "type": "string"
        }
      }
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "password",
        "existingSecret",
        "existingSecretPasswordKey"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "password": {
          "type": "string"
        },
        "existingSecret": {
          "type": "string"
        },
        "existingSecretPasswordKey": {
          "type": "string"
        }
      }
    },
    "redis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "port",
        "appendonly",
        "protectedMode",
        "extraArgs",
        "primaryExtraArgs",
        "replicaExtraArgs"
      ],
      "properties": {
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "appendonly": {
          "type": "boolean"
        },
        "protectedMode": {
          "type": "boolean"
        },
        "extraArgs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "primaryExtraArgs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "replicaExtraArgs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "podSecurityContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "fsGroup",
        "fsGroupChangePolicy"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "fsGroup": {
          "type": "integer",
          "minimum": 1
        },
        "fsGroupChangePolicy": {
          "type": "string",
          "enum": [
            "Always",
            "OnRootMismatch"
          ]
        }
      }
    },
    "containerSecurityContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "allowPrivilegeEscalation",
        "runAsNonRoot",
        "capabilities",
        "seccompProfile"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "allowPrivilegeEscalation": {
          "type": "boolean"
        },
        "runAsNonRoot": {
          "type": "boolean"
        },
        "capabilities": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "drop"
          ],
          "properties": {
            "drop": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            }
          }
        },
        "seccompProfile": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "probes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "startup",
        "liveness",
        "readiness"
      ],
      "properties": {
        "startup": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "failureThreshold",
            "periodSeconds",
            "timeoutSeconds"
          ],
          "properties": {
            "failureThreshold": {
              "type": "integer",
              "minimum": 1
            },
            "periodSeconds": {
              "type": "integer",
              "minimum": 1
            },
            "timeoutSeconds": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "liveness": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "initialDelaySeconds",
            "periodSeconds",
            "failureThreshold",
            "timeoutSeconds"
          ],
          "properties": {
            "initialDelaySeconds": {
              "type": "integer",
              "minimum": 0
            },
            "periodSeconds": {
              "type": "integer",
              "minimum": 1
            },
            "failureThreshold": {
              "type": "integer",
              "minimum": 1
            },
            "timeoutSeconds": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "readiness": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "initialDelaySeconds",
            "periodSeconds",
            "failureThreshold",
            "timeoutSeconds"
          ],
          "properties": {
            "initialDelaySeconds": {
              "type": "integer",
              "minimum": 0
            },
            "periodSeconds": {
              "type": "integer",
              "minimum": 1
            },
            "failureThreshold": {
              "type": "integer",
              "minimum": 1
            },
            "timeoutSeconds": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    },
    "primary": {
      "$ref": "#/definitions/role"
    },
    "replica": {
      "allOf": [
        {
          "$ref": "#/definitions/role"
        },
        {
          "type": "object",
          "required": [
            "replicaCount"
          ],
          "properties": {
            "replicaCount": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      ]
    }
  },
  "required": [
    "image",
    "serviceAccount",
    "auth",
    "redis",
    "podSecurityContext",
    "containerSecurityContext",
    "probes",
    "primary",
    "replica"
  ],
  "definitions": {
    "role": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "service",
        "podAnnotations",
        "podLabels",
        "nodeSelector",
        "tolerations",
        "affinity",
        "resources",
        "persistence"
      ],
      "properties": {
        "service": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "annotations"
          ],
          "properties": {
            "type": {
              "type": "string",
              "minLength": 1
            },
            "annotations": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        },
        "podAnnotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "podLabels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "nodeSelector": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "tolerations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "affinity": {
          "type": "object",
          "additionalProperties": true
        },
        "resources": {
          "type": "object",
          "additionalProperties": true
        },
        "persistence": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "enabled",
            "storageClassName",
            "accessModes",
            "size"
          ],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "storageClassName": {
              "type": "string"
            },
            "accessModes": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "size": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "replicaCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
