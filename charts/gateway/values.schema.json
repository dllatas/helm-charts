{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apiVersion",
    "gateways"
  ],
  "properties": {
    "global": {
      "type": "object",
      "additionalProperties": true
    },
    "apiVersion": {
      "type": "string",
      "enum": [
        "gateway.networking.k8s.io/v1"
      ]
    },
    "gateways": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "namespace",
          "spec"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
          },
          "namespace": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
          },
          "labels": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "annotations": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "spec": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "gatewayClassName",
              "listeners"
            ],
            "properties": {
              "gatewayClassName": {
                "type": "string",
                "minLength": 1
              },
              "listeners": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        }
      }
    }
  }
}
