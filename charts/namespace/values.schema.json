{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["name"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 63,
      "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
    },
    "labels": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    },
    "annotations": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    },
    "finalizers": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    }
  }
}
