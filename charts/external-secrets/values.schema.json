{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["externalSecrets"],
  "properties": {
    "externalSecrets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "namespace", "secretStoreRef", "target"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 63,
            "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
          },
          "namespace": {
            "type": "string",
            "minLength": 1,
            "maxLength": 63,
            "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
          },
          "refreshInterval": {"type": "string", "minLength": 1},
          "labels": {
            "type": "object",
            "additionalProperties": {"type": "string"}
          },
          "annotations": {
            "type": "object",
            "additionalProperties": {"type": "string"}
          },
          "secretStoreRef": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "name"],
            "properties": {
              "kind": {
                "type": "string",
                "enum": ["SecretStore", "ClusterSecretStore"]
              },
              "name": {"type": "string", "minLength": 1}
            }
          },
          "target": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "properties": {
              "name": {"type": "string", "minLength": 1},
              "creationPolicy": {"type": "string", "minLength": 1},
              "deletionPolicy": {"type": "string", "minLength": 1},
              "immutable": {"type": "boolean"},
              "template": {"type": "object", "additionalProperties": true}
            }
          },
          "data": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["secretKey", "remoteRef"],
              "properties": {
                "secretKey": {"type": "string", "minLength": 1},
                "remoteRef": {
                  "type": "object",
                  "additionalProperties": true,
                  "required": ["key"],
                  "properties": {
                    "key": {"type": "string", "minLength": 1}
                  }
                }
              }
            }
          },
          "dataFrom": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": true,
              "minProperties": 1
            }
          }
        },
        "oneOf": [
          {"required": ["data"]},
          {"required": ["dataFrom"]}
        ]
      }
    }
  }
}
